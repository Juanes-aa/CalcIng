{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["src/engine/*"],
      "@/*": ["src/*"]
    },
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "src", "tests"],
  "exclude": ["tests/runner.ts"]
}