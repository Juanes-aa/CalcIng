# --- CalcIng Frontend ---
# Copiar este archivo como .env y ajustar los valores.

# URL base del backend (sin trailing slash)
VITE_API_URL=http://localhost:8001

# Activar backend SymPy (true = sympyAdapter, false = nerdamer offline)
VITE_USE_BACKEND=false

# Mercado Pago Plan IDs (públicos, no son secrets)
# Obtener creando preapproval_plan vía API (ver MIGRATION_STRIPE_TO_MERCADOPAGO.md)
VITE_MP_PLAN_PRO_MONTHLY=
VITE_MP_PLAN_PRO_ANNUAL=
VITE_MP_PLAN_ENTERPRISE_MONTHLY=
VITE_MP_PLAN_ENTERPRISE_ANNUAL=
