
# Base de datos (Supabase Postgres en producción, sqlite local en dev)
# Producción ejemplo:
#   postgresql+asyncpg://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./calcIng_dev.db

# Redis (Upstash en producción)
# Producción ejemplo: rediss://default:TOKEN@xxxxx.upstash.io:6379
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=60

# Concurrencia (ProcessPoolExecutor)
MAX_WORKERS=4

# Límites
MAX_REQUEST_BODY_BYTES=65536
PASSWORD_MIN_LENGTH=8

# JWT RS256 — generar con:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Pegar el contenido completo (incluyendo BEGIN/END) entre comillas dobles.
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# Mercado Pago (modo test: TEST-... o APP_USR-... según país)
# Access Token: panel.mercadopago.com → Aplicación → Credenciales de prueba
MP_ACCESS_TOKEN=
# Webhook secret: se genera al crear el webhook en el panel de MP. Vacío en dev.
MP_WEBHOOK_SECRET=
# Plan IDs: salida de POST /preapproval_plan (ver MIGRATION_STRIPE_TO_MERCADOPAGO.md)
MP_PLAN_PRO_MONTHLY=
MP_PLAN_PRO_ANNUAL=
MP_PLAN_ENTERPRISE_MONTHLY=
MP_PLAN_ENTERPRISE_ANNUAL=
